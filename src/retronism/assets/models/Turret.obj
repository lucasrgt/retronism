# IK CCD showcase: 3-bone turret arm.
#   turret_base (yaw center) → turret_arm (forward-offset) → turret_tip (further offset)
# CCD rotates base + arm to bring turret_tip's pivot toward the player target.
# Hierarchical render makes parent rotations propagate to children automatically.

vt 0 0
vt 1 0
vt 1 1
vt 0 1

# --- turret_base: floor cube 0.25..0.75 / 0..0.5 / 0.25..0.75 ---
o turret_base
v 0.25 0.0 0.25
v 0.75 0.0 0.25
v 0.75 0.0 0.75
v 0.25 0.0 0.75
v 0.25 0.5 0.25
v 0.75 0.5 0.25
v 0.75 0.5 0.75
v 0.25 0.5 0.75
f 5/1 6/2 7/3 8/4
f 1/1 4/2 3/3 2/4
f 1/1 2/2 6/3 5/4
f 2/1 3/2 7/3 6/4
f 3/1 4/2 8/3 7/4
f 4/1 1/2 5/3 8/4

# --- turret_arm: forward-offset cube 0.4..0.6 / 0.5..0.7 / 0.6..0.8 ---
o turret_arm
v 0.4 0.5 0.6
v 0.6 0.5 0.6
v 0.6 0.5 0.8
v 0.4 0.5 0.8
v 0.4 0.7 0.6
v 0.6 0.7 0.6
v 0.6 0.7 0.8
v 0.4 0.7 0.8
f 13/1 14/2 15/3 16/4
f 9/1 12/2 11/3 10/4
f 9/1 10/2 14/3 13/4
f 10/1 11/2 15/3 14/4
f 11/1 12/2 16/3 15/4
f 12/1 9/2 13/3 16/4

# --- turret_tip: end marker cube 0.45..0.55 / 0.7..0.8 / 0.85..0.95 ---
o turret_tip
v 0.45 0.7 0.85
v 0.55 0.7 0.85
v 0.55 0.7 0.95
v 0.45 0.7 0.95
v 0.45 0.8 0.85
v 0.55 0.8 0.85
v 0.55 0.8 0.95
v 0.45 0.8 0.95
f 21/1 22/2 23/3 24/4
f 17/1 20/2 19/3 18/4
f 17/1 18/2 22/3 21/4
f 18/1 19/2 23/3 22/4
f 19/1 20/2 24/3 23/4
f 20/1 17/2 21/3 24/4
